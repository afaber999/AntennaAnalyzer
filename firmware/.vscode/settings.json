{
  "C_Cpp.intelliSenseEngine": "default",
  "idf.espIdfPathWin": "${env:IDF_PATH}",
  "idf.pythonInstallPath": "${env:IDF_PYTHON_ENV_PATH}\\Scripts\\python.exe",
  "idf.openOcdConfigs": [
    "interface/ftdi/esp32_devkitj_v1.cfg",
    "target/esp32s3.cfg"
  ],
  "idf.portWin": "COM3",
  "idf.toolsPathWin": "${env:IDF_TOOLS_PATH}",
  "idf.customExtraVars": {
    "IDF_TARGET": "esp32s3"
  },
  "clangd.path": "${env:ESP_CLANGD_PATH}",
  "clangd.arguments": [
    "--background-index",
    "--query-driver=**",
    "--compile-commands-dir=e:\\esptest\\gfx_tester\\build"
  ],
  "idf.flashType": "UART"
}